NODE_ENV=development

POSTGRES_USER=cyberstore
POSTGRES_PASSWORD=cyberstore_password
POSTGRES_DB=cyberstore_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cyberstore:cyberstore_password@postgres:5432/cyberstore_db?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

API_PREFIX=/api/v1
ENABLE_SWAGGER=true
ENABLE_VULNERABLE_LAB=false

NGINX_PORT=8080
FRONTEND_PORT=5173
BACKEND_PORT=3000

# Local default:
FRONTEND_ORIGIN=http://localhost:8080
VITE_API_URL=/api/v1
VITE_PUBLIC_HOST=localhost
VITE_HMR_CLIENT_PORT=8080
VITE_HMR_PROTOCOL=ws

# VirtualBox Host-only lab example:
# Ubuntu Server VM Host-only IP: 192.168.56.10
# Use Nginx as the browser/API target. Keep VITE_API_URL relative so the
# frontend consumes the API through the same Nginx origin.
# FRONTEND_ORIGIN=http://192.168.56.10:8080
# VITE_API_URL=/api/v1
# VITE_PUBLIC_HOST=192.168.56.10
# VITE_HMR_CLIENT_PORT=8080
# VITE_HMR_PROTOCOL=ws
